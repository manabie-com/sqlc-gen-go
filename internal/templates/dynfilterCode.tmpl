{{define "dynfilterCode"}}
// DynamicSQL processes a SQL query with -- :if $N annotations.
// For each annotated line, it checks args[N-1] (N is 1-based, matching $N):
//   - nil pointer → skip the line
//   - false bool → skip the line
//   - otherwise → keep the line
//
// After filtering, remaining $N placeholders are renumbered sequentially and
// the args slice is trimmed to match, so the query is always valid.
func DynamicSQL(query string, args []any) (string, []any) {
	lines := strings.Split(query, "\n")
	var kept []string
	skipNext := false

	for _, line := range lines {
		trimmed := strings.TrimSpace(line)

		// Standalone block annotation: "-- :if $N"
		if strings.HasPrefix(trimmed, "-- :if $") {
			if rest := strings.TrimPrefix(trimmed, "-- :if $"); rest != "" {
				if n, err := strconv.Atoi(rest); err == nil {
					if n-1 < len(args) && !dynArgActive(args[n-1]) {
						skipNext = true
					}
					continue
				}
			}
		}

		if skipNext {
			skipNext = false
			continue
		}

		// Inline annotation(s): "content -- :if $N [-- :if $M ...]"
		// The line is dropped if any condition is inactive; all annotations are
		// stripped when the line is kept.
		if idx := strings.Index(line, " -- :if $"); idx != -1 {
			skip := false
			tail := line[idx:]
			for len(tail) > 0 {
				i := strings.Index(tail, " -- :if $")
				if i == -1 {
					break
				}
				rest := tail[i+len(" -- :if $"):]
				end := strings.IndexAny(rest, " \t")
				numStr := rest
				if end != -1 {
					numStr = rest[:end]
				}
				if n, err := strconv.Atoi(numStr); err == nil {
					if n-1 < len(args) && !dynArgActive(args[n-1]) {
						skip = true
						break
					}
				}
				tail = tail[i+1:]
			}
			if skip {
				continue
			}
			line = strings.TrimRight(line[:idx], " \t")
		}

		kept = append(kept, line)
	}

	// Strip a dangling trailing comma: when the last item in a list (ORDER BY,
	// SELECT columns, etc.) is removed, the previously-last item may be left
	// with a trailing comma that produces invalid SQL.
	for i := len(kept) - 1; i >= 0; i-- {
		if strings.TrimSpace(kept[i]) == "" {
			continue
		}
		noTrail := strings.TrimRight(kept[i], " \t")
		if strings.HasSuffix(noTrail, ",") {
			kept[i] = noTrail[:len(noTrail)-1]
		}
		break
	}

	return dynRemapPlaceholders(strings.Join(kept, "\n"), args)
}

// dynRemapPlaceholders renumbers $N placeholders sequentially (in order of
// first appearance) and returns only the args that are still referenced.
// This is necessary because DynamicSQL may remove lines that contain $N
// references, leaving gaps that would cause "expected M arguments, got N" errors.
func dynRemapPlaceholders(query string, args []any) (string, []any) {
	var buf strings.Builder
	oldToNew := map[int]int{}
	nextNew := 1

	i := 0
	for i < len(query) {
		if query[i] == '$' && i+1 < len(query) && query[i+1] >= '0' && query[i+1] <= '9' {
			j := i + 1
			for j < len(query) && query[j] >= '0' && query[j] <= '9' {
				j++
			}
			n, _ := strconv.Atoi(query[i+1 : j])
			if _, ok := oldToNew[n]; !ok {
				oldToNew[n] = nextNew
				nextNew++
			}
			buf.WriteByte('$')
			buf.WriteString(strconv.Itoa(oldToNew[n]))
			i = j
		} else {
			buf.WriteByte(query[i])
			i++
		}
	}

	newArgs := make([]any, len(oldToNew))
	for old, newIdx := range oldToNew {
		if old-1 < len(args) {
			newArgs[newIdx-1] = args[old-1]
		}
	}

	return buf.String(), newArgs
}

func dynArgActive(arg any) bool {
	if arg == nil {
		return false
	}
	v := reflect.ValueOf(arg)
	switch v.Kind() {
	case reflect.Ptr, reflect.Interface:
		return !v.IsNil()
	case reflect.Bool:
		return v.Bool()
	default:
		return true
	}
}
