{{define "dynfilterCode"}}
// DynamicSQL processes a SQL query with -- :if $N annotations.
// For each annotated line, it checks args[N-1] (N is 1-based, matching $N):
//   - nil pointer → skip the line
//   - false bool → skip the line
//   - otherwise → keep the line
//
// After filtering, remaining $N placeholders are renumbered sequentially and
// the args slice is trimmed to match, so the query is always valid.
func DynamicSQL(query string, args []any) (string, []any) {
	kept := make([]string, 0, 16)
	skipNext := false

	rest := query
	for rest != "" {
		var line string
		if i := strings.IndexByte(rest, '\n'); i >= 0 {
			line, rest = rest[:i], rest[i+1:]
		} else {
			line, rest = rest, ""
		}

		trimmed := strings.TrimSpace(line)

		// Standalone block annotation: "-- :if $N"
		if after, ok := strings.CutPrefix(trimmed, "-- :if $"); ok && after != "" {
			if n := dynParseInt(after, len(after)); n > 0 && n-1 < len(args) && !dynArgActive(args[n-1]) {
				skipNext = true
			}
			continue
		}

		if skipNext {
			skipNext = false
			continue
		}

		// Inline annotation(s): "content -- :if $N [-- :if $M ...]"
		if idx := strings.Index(line, " -- :if $"); idx != -1 {
			skip := false
			tail := line[idx:]
			for len(tail) > 0 {
				i := strings.Index(tail, " -- :if $")
				if i == -1 {
					break
				}
				numStart := i + 9 // len(" -- :if $") == 9
				numEnd := numStart
				for numEnd < len(tail) && tail[numEnd] >= '0' && tail[numEnd] <= '9' {
					numEnd++
				}
				if numEnd > numStart {
					if n := dynParseInt(tail[numStart:numEnd], numEnd-numStart); n > 0 && n-1 < len(args) && !dynArgActive(args[n-1]) {
						skip = true
						break
					}
				}
				tail = tail[i+1:]
			}
			if skip {
				continue
			}
			line = strings.TrimRight(line[:idx], " \t")
		}

		kept = append(kept, line)
	}

	// Single backward pass:
	//  1. Strip a dangling trailing comma from the last non-empty line.
	//  2. Remove an orphaned ORDER BY whose items were all filtered out.
	trailingCommaDone := false
	for i := len(kept) - 1; i >= 0; i-- {
		trimmed := strings.TrimSpace(kept[i])
		if trimmed == "" {
			continue
		}
		if !trailingCommaDone {
			noTrail := strings.TrimRight(kept[i], " \t")
			if noTrail[len(noTrail)-1] == ',' {
				kept[i] = noTrail[:len(noTrail)-1]
			}
			trailingCommaDone = true
		}
		if trimmed == "ORDER BY" {
			kept = append(kept[:i], kept[i+1:]...)
			break
		}
		break
	}

	return dynRemapPlaceholders(strings.Join(kept, "\n"), args)
}

// dynParseInt parses a non-negative integer from s[0:length] without allocations.
// Returns -1 if the string contains non-digit characters.
func dynParseInt(s string, length int) int {
	n := 0
	for i := 0; i < length; i++ {
		c := s[i]
		if c < '0' || c > '9' {
			return -1
		}
		n = n*10 + int(c-'0')
	}
	return n
}

// dynWriteInt writes a positive integer to buf without allocations for values < 10.
func dynWriteInt(buf *strings.Builder, n int) {
	if n < 10 {
		buf.WriteByte(byte('0' + n))
	} else if n < 100 {
		buf.WriteByte(byte('0' + n/10))
		buf.WriteByte(byte('0' + n%10))
	} else {
		// Rare: queries with 100+ params. Use a small stack buffer.
		var tmp [20]byte
		i := len(tmp)
		for n > 0 {
			i--
			tmp[i] = byte('0' + n%10)
			n /= 10
		}
		buf.Write(tmp[i:])
	}
}

// dynRemapPlaceholders renumbers $N placeholders sequentially (in order of
// first appearance) and returns only the args that are still referenced.
func dynRemapPlaceholders(query string, args []any) (string, []any) {
	var buf strings.Builder
	buf.Grow(len(query))

	oldToNew := make(map[int]int)
	nextNew := 1

	for i := 0; i < len(query); {
		if query[i] == '$' && i+1 < len(query) && query[i+1] >= '0' && query[i+1] <= '9' {
			j := i + 1
			for j < len(query) && query[j] >= '0' && query[j] <= '9' {
				j++
			}
			n := dynParseInt(query[i+1:j], j-i-1)
			if n > 0 {
				if oldToNew[n] == 0 {
					oldToNew[n] = nextNew
					nextNew++
				}
				buf.WriteByte('$')
				dynWriteInt(&buf, oldToNew[n])
			} else {
				buf.WriteString(query[i:j])
			}
			i = j
		} else {
			buf.WriteByte(query[i])
			i++
		}
	}

	newArgs := make([]any, nextNew-1)
	for old, newIdx := range oldToNew {
		if old-1 < len(args) {
			newArgs[newIdx-1] = args[old-1]
		}
	}

	return buf.String(), newArgs
}

func dynArgActive(arg any) bool {
	if arg == nil {
		return false
	}
	switch v := arg.(type) {
	case bool:
		return v
	case *string:
		return v != nil
	case *int:
		return v != nil
	case *int32:
		return v != nil
	case *int64:
		return v != nil
	case *float64:
		return v != nil
	case *bool:
		return v != nil
	}
	v := reflect.ValueOf(arg)
	switch v.Kind() {
	case reflect.Ptr, reflect.Interface:
		return !v.IsNil()
	default:
		return true
	}
}
