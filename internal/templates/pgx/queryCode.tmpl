{{if eq .Cmd ":one"}}
{{range .Comments}}//{{.}}
{{end -}}
{{- if $.EmitMethodsWithDBArgument -}}
func (q *{{$.StructName}}) {{.MethodName}}(ctx context.Context, db DBTX, {{.Arg.Pair}}) ({{.Ret.DefineType}}, error) {
{{tracingCode .MethodName}}{{- if .HasDynFilter}}	dynQuery, dynArgs := {{.DynQueryVar}}.Build([]any{ {{.DynFilterArgs}} })
	row := db.QueryRow(ctx, dynQuery, dynArgs...)
{{- else}}	row := db.QueryRow(ctx, {{.ConstantName}}, {{.Arg.Params}})
{{- end}}
{{- else -}}
func (q *{{$.StructName}}) {{.MethodName}}(ctx context.Context, {{.Arg.Pair}}) ({{.Ret.DefineType}}, error) {
{{tracingCode .MethodName}}{{- if .HasDynFilter}}	dynQuery, dynArgs := {{.DynQueryVar}}.Build([]any{ {{.DynFilterArgs}} })
	row := q.db.QueryRow(ctx, dynQuery, dynArgs...)
{{- else}}	row := q.db.QueryRow(ctx, {{.ConstantName}}, {{.Arg.Params}})
{{- end}}
{{- end}}
	{{- if or (ne .Arg.Pair .Ret.Pair) (ne .Arg.DefineType .Ret.DefineType) }}
	var {{.Ret.Name}} {{.Ret.Type}}
	{{- end}}
	err := row.Scan({{.Ret.Scan}})
	{{- if and $.EmitErrNilIfNoRows .IsSelect}}
	if errors.Is(err, pgx.ErrNoRows) {
		{{- if hasPrefix .Ret.DefineType "*"}}
		return nil, nil
		{{- else}}
		return {{.Ret.Name}}, nil
		{{- end}}
	}
	{{- end }}
	{{- if $.WrapErrors}}
	if err != nil {
		err = fmt.Errorf("query {{.MethodName}}: %w", err)
	}
	{{- end}}
	return {{.Ret.ReturnName}}, err
}
{{end}}

{{if eq .Cmd ":many"}}
{{range .Comments}}//{{.}}
{{end -}}
{{- if $.EmitMethodsWithDBArgument -}}
func (q *{{$.StructName}}) {{.MethodName}}(ctx context.Context, db DBTX, {{.Arg.Pair}}) ([]{{.Ret.SliceType}}, error) {
{{tracingCode .MethodName}}{{- if .HasDynFilter}}	dynQuery, dynArgs := {{.DynQueryVar}}.Build([]any{ {{.DynFilterArgs}} })
	rows, err := db.Query(ctx, dynQuery, dynArgs...)
{{- else}}	rows, err := db.Query(ctx, {{.ConstantName}}, {{.Arg.Params}})
{{- end}}
{{- else -}}
func (q *{{$.StructName}}) {{.MethodName}}(ctx context.Context, {{.Arg.Pair}}) ([]{{.Ret.SliceType}}, error) {
{{tracingCode .MethodName}}{{- if .HasDynFilter}}	dynQuery, dynArgs := {{.DynQueryVar}}.Build([]any{ {{.DynFilterArgs}} })
	rows, err := q.db.Query(ctx, dynQuery, dynArgs...)
{{- else}}	rows, err := q.db.Query(ctx, {{.ConstantName}}, {{.Arg.Params}})
{{- end}}
{{- end}}
	if err != nil {
		return nil, {{if $.WrapErrors}}fmt.Errorf("query {{.MethodName}}: %w", err){{else}}err{{end}}
	}
	defer rows.Close()
	{{- if $.EmitEmptySlices}}
	items := []{{.Ret.SliceType}}{}
	{{else}}
	var items []{{.Ret.SliceType}}
	{{end -}}
	for rows.Next() {
		var {{.Ret.Name}} {{.Ret.Type}}
		if err := rows.Scan({{.Ret.Scan}}); err != nil {
			return nil, {{if $.WrapErrors}}fmt.Errorf("query {{.MethodName}}: %w", err){{else}}err{{end}}
		}
		items = append(items, {{.Ret.SliceReturnName}})
	}
	if err := rows.Err(); err != nil {
		return nil, {{if $.WrapErrors}}fmt.Errorf("query {{.MethodName}}: %w", err){{else}}err{{end}}
	}
	return items, nil
}
{{end}}

