{{escape .SQL}}
{{$.Q}}
{{if .HasDynFilter}}var {{.DynQueryVar}} = dynCompile({{.ConstantName}})
{{end}}
{{end}}

{{if ne (hasPrefix .Cmd ":batch") true}}
{{if .Arg.EmitStruct}}
